<%- include('../partials/header') %>

<link rel="stylesheet" href="/styles/styles.css">

<div class="container">
    <div class="hero">
        <h1>Estoque da Livraria</h1>
        <p>Gerencie os títulos disponíveis no centro</p>
    </div>

    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 30px;">
        <div class="card" style="border-top: 5px solid #1277bb; text-align: center;">
            <h3 style="color: #666; font-size: 0.9em;">TOTAL DE VENDAS NO MÊS</h3>
            <p style="font-size: 1.8em; font-weight: bold; color: #1277bb; margin: 10px 0;">
                R$ <%= totalVendidoMes.toFixed(2) %>
            </p>
        </div>

        <div class="card" style="border-top: 5px solid #28a745;">
            <h3 style="color: #666; font-size: 0.9em; text-align: center;">TOP 5 mais vendidos neste Mês</h3>
            <ul style="list-style: none; padding: 0; margin-top: 10px; font-size: 0.85em;">
                <% top5.forEach(([titulo, qtd], index) => { %>
                    <li style="margin-bottom: 5px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                        <strong><%= index + 1 %>º</strong> <%= titulo %> (<%= qtd %>)
                    </li>
                <% }) %>
            </ul>
        </div>

        <div class="card" style="border-top: 5px solid #ff4d4d; text-align: center;">
            <h3 style="color: #666; font-size: 0.9em;">AVISO DE REPOSIÇÃO</h3>
            <p style="font-size: 2em; font-weight: bold; color: #ff4d4d; margin: 10px 0;">
                <%= totalAlertas %>
            </p>
            <small style="color: #999;">Livros abaixo da média de giro</small>
        </div>
    </div>

    <div style="margin-bottom: 20px; display: flex; justify-content: flex-end;">
        <a href="/livraria/cadastro" class="btn-atender" style="background-color: #28a745;">+ Cadastrar Novo Livro</a>
    </div>

    <div class="card">
        <table>
            <thead>
                <tr>
                    <th>Capa</th>
                    <th>Título</th>
                    <th>Editora</th>
                    <th>Autor / Espírito</th>
                    <th>Estoque</th>
                    <th>Preço Venda</th>
                    <th>Giro (90/180/365d)</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                <% livros.forEach(livro => { %>
                <tr>
                    <td>
                        <img src="https://covers.openlibrary.org/b/isbn/<%= livro._id %>-S.jpg" 
                             onerror="this.src='https://via.placeholder.com/40x60?text=N/A'" 
                             width="40" style="border-radius: 4px;">
                    </td>
                    
                    <td><strong><%= livro.titulo %></strong><br><small style="color:#999"><%= livro._id %></small></td>
                    
                    <td><span class="badge-editora"><%= livro.editora || '---' %></span></td>
                    
                    <td>
                        <%= livro.autor %><br>
                        <small style="color: #666;">
                            <%= livro.ditadoPor ? 'Espírito: ' + livro.ditadoPor : '' %>
                        </small>
                    </td>

                    <td>
                        <span class="status-badge <%= livro.estoque_atual <= (livro.estoque_minimo || 2) ? 'alerta' : 'atendimento' %>">
                            <%= livro.estoque_atual %> un
                        </span>
                    </td>

                    <td>R$ <%= livro.preco_venda.toFixed(2) %></td>

                    <td>
                        <div style="font-size: 0.9em; display: flex; gap: 5px;">
                            <span title="90 dias" style="color: #1277bb; font-weight: bold;"><%= livro.vendas90 %></span>
                            <span style="color: #ccc;">|</span>
                            <span title="180 dias" style="color: #666;"><%= livro.vendas180 %></span>
                            <span style="color: #ccc;">|</span>
                            <span title="365 dias" style="color: #999;"><%= livro.vendas365 %></span>
                        </div>
                    </td>

                    <td>
                        <div style="display: flex; gap: 10px; align-items: center;">
                            <a href="/livraria/editar/<%= livro._id %>" class="muted">Editar</a>
                            <div style="display: flex; gap: 5px; align-items: center; border-left: 1px solid #ddd; padding-left: 10px;">
                                <input type="number" id="qtd-<%= livro._id %>" value="1" min="1" style="width: 40px; text-align: center;">
                                <button onclick="vender('<%= livro._id %>')" class="btn-atender" style="background-color: #28a745; padding: 5px 10px; font-size: 12px;">
                                    Vender
                                </button>
                            </div>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
async function vender(isbn) {
    const qtdInput = document.getElementById(`qtd-${isbn}`);
    const qtd = qtdInput.value;
    
    if (!confirm(`Confirmar a venda de ${qtd} unidade(s)?`)) return;

    try {
        const response = await fetch('/livraria/venda-rapida', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ isbn, qtd })
        });

        if (response.ok) {
            Swal.fire({
                title: 'Venda Realizada!',
                icon: 'success',
                timer: 1500,
                showConfirmButton: false
            }).then(() => { location.reload(); });
        } else {
            const data = await response.json();
            alert(data.erro || "Estoque insuficiente.");
        }
    } catch (error) {
        alert("Erro ao conectar com o servidor.");
    }
}

const urlParams = new URLSearchParams(window.location.search);
if (urlParams.has('sucesso')) {
    Swal.fire({ title: 'Livro Salvo!', icon: 'success' });
} else if (urlParams.has('atualizado')) {
    Swal.fire({ title: 'Atualizado!', icon: 'success' });
}
</script>

<%- include('../partials/footer') %>