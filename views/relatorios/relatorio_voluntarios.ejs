<%- include('../partials/header') %>
<link rel="stylesheet" href="/styles/styles.css">

<main class="hero">
    <h1>Relatorio de Voluntarios Ativos</h1>
    <p>Visao de participacao recente dos terapeutas que ja realizaram atendimentos no sistema.</p>

    <section class="dashboard-grid" style="margin: 24px 0;">
        <article class="stat-card">
            <h3>Participaram nos ultimos 30 dias</h3>
            <p style="font-size: 2rem; font-weight: 700; margin: 8px 0 0;"><%= resumo.ativos30Dias %></p>
        </article>
    </section>

    <div style="width: 90%; margin: 0 auto 20px; text-align: left;">
        <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
            <input
                type="text"
                id="inputNomeVoluntario"
                placeholder="Buscar por nome..."
                style="padding: 8px; width: 280px; border: 1px solid #ccc; border-radius: 4px;"
            >
            <p style="margin: 0;">Exibindo: <strong id="totalExibido"><%= voluntarios.length %></strong></p>
        </div>
    </div>

    <div class="form-container">
        <table class="table-atendimentos" id="tabelaVoluntarios">
            <thead>
                <tr>
                    <th>Nome do Voluntario</th>
                    <th>Ultima Participacao</th>
                </tr>
            </thead>
            <tbody>
                <% if (voluntarios && voluntarios.length > 0) { %>
                    <% voluntarios.forEach(v => { %>
                        <tr>
                            <td><strong><%= v._id || 'Nao informado' %></strong></td>
                            <td><%= v.ultimaParticipacao ? new Date(v.ultimaParticipacao).toLocaleDateString('pt-BR') : '-' %></td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="2">Nenhum voluntario encontrado no historico.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</main>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const inputNome = document.getElementById('inputNomeVoluntario');
        const tabela = document.getElementById('tabelaVoluntarios');
        const linhas = tabela.querySelector('tbody').getElementsByTagName('tr');
        const contador = document.getElementById('totalExibido');

        function filtrarTabela() {
            const filtroNome = inputNome.value.toLowerCase().trim();
            let visiveis = 0;

            Array.from(linhas).forEach((linha) => {
                const colunas = linha.getElementsByTagName('td');
                if (colunas.length > 0) {
                    const textoNome = colunas[0].textContent.toLowerCase();
                    const correspondeNome = textoNome.includes(filtroNome);

                    if (correspondeNome) {
                        linha.style.display = '';
                        visiveis++;
                    } else {
                        linha.style.display = 'none';
                    }
                }
            });

            contador.textContent = visiveis;
        }

        inputNome.addEventListener('input', filtrarTabela);
    });
</script>

<%- include('../partials/footer') %>
